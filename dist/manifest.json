{
  "manifest_version": 3,
  "name": "JCRLattes",
  "version": "1.5.2",
  "description": "Anote o Fator de Impacto (JCR) no Currículo Lattes, analise autoria e gere relatórios estatísticos de produção científica.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://*.researcherid.com/*",
    "*://*.webofscience.com/*"
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-32.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    },
    "default_title": "JCRLattes"
  },
  "content_scripts": [
    {
      "matches": [
        "http://buscatextual.cnpq.br/buscatextual/visualizacv.do*",
        "https://buscatextual.cnpq.br/buscatextual/visualizacv.do*"
      ],
      "js": [
        "scripts/report_utils.js",
        "scripts/db_tools.js",
        "scripts/content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "images/*.png",
        "images/*.jpg"
      ],
      "matches": [
        "http://buscatextual.cnpq.br/*",
        "https://buscatextual.cnpq.br/*"
      ]
    }
  ]
}